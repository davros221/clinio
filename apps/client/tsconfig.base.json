{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@clinio/shared": ["packages/shared/src/index.ts"],
      "@clinio/api": ["packages/api/src/index.ts"]
    }
  }
}
