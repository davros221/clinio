{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "rootDir": "../..",
    "noEmit": true,
    "composite": true,
    "allowImportingTsExtensions": true,

    // Vite/React specific overrides (Root is nodenext)
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // Path Aliases
    "baseUrl": ".",
    "paths": {
      "@clinio/shared": ["../../packages/shared/src/index.ts"],
      "@clinio/api": ["../../packages/api/src/index.ts"],
      "@api": ["./src/api/index.ts"],
      "@pages": ["./src/pages/index.tsx"],
      "@components": ["./src/components/index.ts"]
    },

    "types": [
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "vite/client",
      "react-router"
    ]
  },
  "references": [
    { "path": "../../packages/api/tsconfig.lib.json" },
    { "path": "../../packages/shared/tsconfig.lib.json" }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "src/**/*.spec.jsx",
    "src/**/*.test.jsx",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
